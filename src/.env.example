# === Gisst Agent Config ===

# Working directory for the agent (where it operates on the VM)
GISST_WORK_DIR=/home/gisst/workspace

# Claude model (claude-opus-4-6, claude-sonnet-4-6)
CLAUDE_MODEL=claude-sonnet-4-6

# Agent process timeout in ms (5 min default)
AGENT_TIMEOUT=300000

# === WhatsApp Cloud API (Sprint 2) ===
# WHATSAPP_VERIFY_TOKEN=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=

# === Notion (Sprint 3) ===
# NOTION_API_KEY=
# NOTION_RESEARCH_DB_ID=
# NOTION_DIGEST_DB_ID=

# === Server ===
PORT=3000
WEBHOOK_PATH=/webhook
