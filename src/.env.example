# === Telegram ===
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# === Gisst Agent Config ===

# Working directory for the agent (where it operates on the VM)
GISST_WORK_DIR=/home/gisst/workspace

# Claude model (claude-opus-4-6, claude-sonnet-4-6)
CLAUDE_MODEL=claude-sonnet-4-6

# Agent process timeout in ms (5 min default)
AGENT_TIMEOUT=300000

# === WhatsApp Cloud API ===
WHATSAPP_VERIFY_TOKEN=your_random_verify_string
WHATSAPP_ACCESS_TOKEN=your_permanent_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# === Notion (Sprint 3) ===
# NOTION_API_KEY=
# NOTION_RESEARCH_DB_ID=
# NOTION_DIGEST_DB_ID=

# === Server ===
PORT=3000
WEBHOOK_PATH=/webhook
